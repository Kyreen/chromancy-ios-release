# GEMINI_API_KEY is required only on the server/backend.
# In production, set this in Google Cloud Secret Manager for Cloud Run.
# Do not create VITE_GEMINI_* variables or put Gemini keys in frontend files.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

VITE_REVENUECAT_PUBLIC_ANDROID_KEY=goog_GkUKxtCgSvcETONOPviDMeJtMWw
VITE_REVENUECAT_PUBLIC_IOS_KEY=appl_oknzfsnjrbUcMXyvGxTTgJJHVmM
# Optional override for native Google sign-in. If omitted, the app falls back to the
# Web client ID inside android/app/google-services.json.
VITE_GOOGLE_WEB_CLIENT_ID=51608421110-r384r8dnhr50kcqcrg1ptu80kjitp45c.apps.googleusercontent.com
# REQUIRED for Google sign-in on iPhone/iPad. Native iOS Google Sign-In needs its
# OWN iOS OAuth client ID (NOT the web client ID above). Until this is filled in,
# the app safely disables the Google button instead of crashing.
# How to get it:
#   1. Firebase console -> Project settings -> add an iOS app (bundle id com.chromancy.app).
#   2. Download GoogleService-Info.plist and add it to ios/App/App in Xcode (Copy if needed, target = App).
#   3. Copy the CLIENT_ID value from that plist into VITE_GOOGLE_IOS_CLIENT_ID below.
#   4. Copy REVERSED_CLIENT_ID from that plist and set it as the iOS CFBundleURLScheme
#      in ios/App/App/Info.plist (replace the com.googleusercontent.apps.* value there).
VITE_GOOGLE_IOS_CLIENT_ID=51608421110-m583gbe1uhompr475o7d40870d351pq5.apps.googleusercontent.com
VITE_GOOGLE_IOS_SERVER_CLIENT_ID=51608421110-r384r8dnhr50kcqcrg1ptu80kjitp45c.apps.googleusercontent.com
VITE_RC_PRO_ENTITLEMENT=pro
VITE_PLAY_PRO_PRODUCT_ID=chromancy_pro:monthly
VITE_PLAY_PREMIUM_PRODUCT_ID=chromancy_premium:monthly
VITE_APPLE_PRO_PRODUCT_ID=chromancy_pro
VITE_APPLE_PREMIUM_PRODUCT_ID=chromancy_premium
CHROMANCY_USAGE_SALT=change-this-server-secret
CHROMANCY_ZAR_USD_RATE=18.5
REVENUECAT_WEBHOOK_SECRET=change-this-revenuecat-webhook-secret
CHROMANCY_SUPPORT_SMTP_HOST=
CHROMANCY_SUPPORT_SMTP_PORT=587
CHROMANCY_SUPPORT_SMTP_SECURE=false
CHROMANCY_SUPPORT_SMTP_USER=
CHROMANCY_SUPPORT_SMTP_PASS=
CHROMANCY_SUPPORT_FROM=info@chromancy.online
CHROMANCY_USE_LOCAL_USAGE_STORE=false
CHROMANCY_FREE_TEST_MODE=false
VITE_CHROMANCY_FREE_TEST_MODE=false
CHROMANCY_ALLOW_INSECURE_UID_FALLBACK=false
CHROMANCY_CRASH_LOGS_ENABLED=true
VITE_CHROMANCY_CRASH_LOGS_ENABLED=true
